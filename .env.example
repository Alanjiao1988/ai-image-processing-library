# Shared deployment defaults for this repository
AZURE_CHINA_SUBSCRIPTION_ID=1f587540-6ec9-414c-a0d0-0e792ed8ed63
AZURE_RESOURCE_GROUP=image
AZURE_LOCATION=chinanorth3

# Backend
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_image_app?schema=public
CORS_ORIGIN=http://localhost:5173
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
APPLICATIONINSIGHTS_CONNECTION_STRING=
HEALTH_FRONTEND_STALE_MS=120000
HEALTH_REFRESH_INTERVAL_MS=60000
STORAGE_CAPACITY_BYTES=536870912000
TEMP_RETENTION_HOURS=24
JOB_CLEANUP_INTERVAL_MINUTES=60
MAX_UPLOAD_SIZE_MB=20

# External image provider
IMAGE_PROVIDER=gpt-image
# Supports either a root URL or a base URL that already includes /v1.
IMAGE_API_BASE_URL=https://your-apim-or-provider-gateway.example.com
IMAGE_API_KEY=replace-me
IMAGE_MODEL_NAME=gpt-image-1.5
IMAGE_GENERATE_PATH=/v1/images/generations
IMAGE_EDIT_PATH=/v1/images/edits
IMAGE_VARIATION_PATH=/v1/images/variations
IMAGE_RESPONSE_FORMAT=b64_json
IMAGE_TIMEOUT_MS=120000
IMAGE_MAX_RETRY=2

# Frontend
VITE_API_BASE_URL=http://localhost:3001
VITE_APP_NAME=AI 图片处理与图片库
VITE_HEALTH_REFRESH_MS=60000
VITE_JOB_POLL_INTERVAL_MS=3000
VITE_APPINSIGHTS_CONNECTION_STRING=
