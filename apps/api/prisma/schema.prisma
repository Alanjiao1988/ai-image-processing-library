generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImageMode {
  TEXT_TO_IMAGE
  IMAGE_EDIT
  IMAGE_VARIATION
}

enum GenerationJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum HealthComponentStatus {
  NORMAL
  DEGRADED
  UNAVAILABLE
}

model Folder {
  id           String      @id @default(cuid())
  name         String      @unique
  description  String?
  coverImageId String?
  imageCount   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  coverImage   ImageAsset? @relation("FolderCover", fields: [coverImageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  images       ImageAsset[] @relation("FolderImages")

  @@index([createdAt])
}

model ImageAsset {
  id                  String   @id @default(cuid())
  folderId            String
  fileName            String
  blobPath            String
  thumbnailBlobPath   String?
  sourceMode          ImageMode
  promptText          String?
  sourceImageBlobPath String?
  width               Int?
  height              Int?
  mimeType            String?
  fileSizeBytes       BigInt?
  externalRequestId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  folder              Folder   @relation("FolderImages", fields: [folderId], references: [id], onDelete: Restrict)
  asFolderCover       Folder[] @relation("FolderCover")

  @@index([folderId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model GenerationJob {
  id                String              @id @default(cuid())
  mode              ImageMode
  status            GenerationJobStatus @default(PENDING)
  promptText        String?
  inputImageBlobPath String?
  tempResultBlobPath String?
  errorCode         String?
  errorMessage      String?
  externalRequestId String?
  savedToLibraryAt  DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([createdAt(sort: Desc)])
}

model HealthSnapshot {
  id                  String                @id @default(cuid())
  frontendStatus      HealthComponentStatus
  backendStatus       HealthComponentStatus
  externalAiStatus    HealthComponentStatus
  blobStorageStatus   HealthComponentStatus
  metadataStoreStatus HealthComponentStatus
  recentSuccessRate   Float?
  storageUsagePercent Float?
  checkedAt           DateTime              @default(now())
  details             Json?

  @@index([checkedAt(sort: Desc)])
}
